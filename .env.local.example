# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Moolre ─────────────────────────────────────────────────
# Set MOOLRE_SANDBOX=true while testing, false for production
MOOLRE_SANDBOX=true
MOOLRE_API_USER=your-api-user
MOOLRE_API_KEY=your-private-api-key
MOOLRE_API_PUBKEY=your-public-api-key
MOOLRE_API_VASKEY=your-vas-key-for-sms
MOOLRE_ACCOUNT_NUMBER=your-account-number
MOOLRE_SMS_SENDER_ID=FlowPilot

# ── Google Gemini ────────────────────────────────────────────
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: NEXT_PUBLIC_APP_URL=https://yourapp.vercel.app
